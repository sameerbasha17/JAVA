import numpy as np
from collections import Counter
# Step 1: Define the dataset (Study Hours, Sleep Hours, Result)
data = np.array([
 [8, 6, 'Pass'],
 [7, 7, 'Pass'],
 [6, 8, 'Pass'],
 [3, 6, 'Fail'],
 [2, 5, 'Fail'],
 [1, 4, 'Fail'] ])
# Step 2: Get user input for new student data
try:
 study_hours = int(input("Enter study hours of the new student: "))
 sleep_hours = int(input("Enter sleep hours of the new student: "))
except ValueError:
 print("Please enter valid integer values.")
 exit()
new_student = np.array([study_hours, sleep_hours])
# Step 3: Compute Euclidean distances
def euclidean_distance(point1, point2):
 return np.sqrt(np.sum((point1 - point2) ** 2))
distances = []
for student in data:
 study, sleep, label = student
 point = np.array([int(study), int(sleep)])
 distance = euclidean_distance(new_student, point)
 distances.append((distance, label))
# Step 4: Sort distances and select K nearest neighbors (K=3)
K = 3
distances.sort() # Sort based on distance
nearest_neighbors = distances[:K]
# Step 5: Perform Majority Voting
labels = [label for _, label in nearest_neighbors]
prediction = Counter(labels).most_common(1)[0][0] # Most common class
# Step 6: Display results
print(f"\nNew Student (Study Hours: {new_student[0]}, Sleep Hours: {new_student[1]}) is 
classified as: {prediction}")
